# Next.js (client-safe)
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# After sign-in/sign-up, land in the workspace (also set on ClerkProvider in code)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app/workspace
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app/workspace
# Optional: used by Convex auth.config.ts via the Convex dashboard instead
# CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev
